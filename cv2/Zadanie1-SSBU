#Úloha 5: Vytvorenie triedy a analýza pacientov
class PacientData:
    def __init__(self, path):
        self.df = pd.read_csv(path, encoding='utf-8')

    def count_diagnoses(self):
        self.df.columns = ["patient_name", "diagnosis"]
        print(self.df['diagnosis'].value_counts())

    def get_most_common_diagnosis(self, n):
        print(self.df['diagnosis'].value_counts().head(n))
        #print(self.df['diagnosis'].value_counts().sort_values(ascending=False).head(n))

    def display_summary(self):
        print(self.df.describe())



