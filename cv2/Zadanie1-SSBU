def triedenieLudiPodlaVeku(ages):
    dic = {
        'minor': 0,
        'adult': 0,
        'senior' : 0
    }

    for age in ages:
        if age < 18:
            dic['minor'] += 1
        elif age > 18 and age < 65:
            dic['adult'] += 1
        else:
            dic['senior'] += 1
    print(dic)
    return dic

def poslatlistveku():
    ages = [10,25,36,85,125,1,35]
    triedenieLudiPodlaVeku(ages)
